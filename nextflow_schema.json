{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com///nextflow_schema.json",
  "title": " pipeline parameters",
  "description": "",
  "type": "object",
  "$defs": {
    "input_output_options": {
      "title": "Input/output options",
      "type": "object",
      "fa_icon": "fas fa-terminal",
      "description": "Define where the pipeline should find input data and save output data.",
      "required": ["outdir"],
      "properties": {
        "outdir": {
          "type": "string",
          "format": "directory-path",
          "description": "The output directory where the results will be saved. You have to use absolute paths to storage on Cloud infrastructure.",
          "fa_icon": "fas fa-folder-open",
          "default": "/mnt/VEIL/users/nolanv/pipeline_project/6-26-26"
        }
      }
    }
  },
  "allOf": [
    {
      "$ref": "#/$defs/input_output_options"
    }
  ],
  "properties": {
    "datasets": {
      "type": "string"
    },
    "orf_coord_fields": {
      "type": "string"
    },
    "phidra_dir": {
      "type": "string"
    },
    "pfamDB": {
      "type": "string"
    },
    "pasv_proteins": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["RNR", "PolA"]
    },
    "tophit_proteins": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["helicase"]
    },
    "domain_proteins": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["PolB"]
    },
    "pasv_threshold": {
      "type": "number",
      "default": 0.01
    },
    "pasv_settings": {
      "type": "string",
      "default": "[PolA:[mapped_name:'PolA_putative', roi_start:521, roi_end:923, cat_sites:'668,705,758,762', expected_sigs:['RDKY', 'RDKF', 'RDKL']], RNR:[mapped_name:'RNR_putative', roi_start:437, roi_end:625, cat_sites:'437,439,441,462,438', expected_sigs:['NCECL', 'NCECV']]]"
    },
    "pfam_annotation_map": {
      "type": "string",
      "default": "[PF00136:'rPolB', PF03175:'pPolB']"
    },
    "genofeature_metadata": {
      "type": "string"
    },
    "proteins": {
      "type": "string",
      "default": "[[protein:'helicase', pfamDomain:'/mnt/VEIL/tools/phidra_resources/ida_files/helicase_ida_file_09_30_25.tsv', subjectDB:'/mnt/VEIL/references/helicase/HeliBase_v3_github.fasta'], [protein:'PolB', pfamDomain:'/mnt/VEIL/tools/phidra_resources/ida_files/polb_PF08490_PR00136_PF03175_ida_file.tsv', subjectDB:'/mnt/VEIL/tools/phidra_resources/subject_db/polb_refs_pPolB_rPolB_piPolB.fasta'], [protein:'PolA', pfamDomain:'/mnt/VEIL/users/nolanv/pipeline_project/Pipeline_production_unused/pola_PF00476_ida_file.tsv', subjectDB:'/mnt/VEIL/references/polA/uniprotkb_DNA_polymerase_A_2023_10_13.fasta', pasv_align_refs:'/mnt/VEIL/references/pasv/pasv_profile/pola_16_k12_ref.fa']]"
    },
    "nn": {
      "type": "array",
      "items": { "type": "integer", "minimum": 2 },
      "default": [75, 100]
    },
    "md": {
      "type": "array",
      "items": { "type": "number", "minimum": 0, "maximum": 1 },
      "default": [0.0, 0.3, 0.5, 0.7]
    },
    "mc": {
      "type": "array",
      "items": { "type": "integer", "minimum": 2 },
      "default": [10, 30]
    },
    "excluded_genofeatures": {
      "type": "string",
      "default": "[]"
    },
    "exclude_datasets": {
      "type": "string",
      "default": "[]"
    },
    "final_md": {
      "type": "number",
      "default": 0.7
    },
    "final_nn": {
      "type": "integer",
      "default": 100
    },
    "final_analysis": {
      "type": "boolean"
    }
  }
}
